APP_ENV=dev
APP_NAME=Mnemosyne

DATABASE_URL=postgresql+asyncpg://mnemosyne:mnemosyne@localhost:5433/mnemosyne
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mnemosyne
MINIO_SECRET_KEY=mnemosyne-secret
MINIO_BUCKET=mnemosyne-artifacts

# CyberdyneAuth (see docs/auth-integration.md)
CYBERDYNEAUTH_ISSUER=https://auth.backend.coolify.cyberdynecorp.ai
CYBERDYNEAUTH_TOKEN_ISSUER=cyberdyne-auth
CYBERDYNEAUTH_CLIENT_ID=cyb_50UdgxXphi9SJJQX
CYBERDYNEAUTH_CLIENT_SECRET=
AUTH_VALIDATION_MODE=jwks
REQUIRED_ENTITLEMENT=cyb_50UdgxXphi9SJJQX
SERVICE_AUDIENCE=mnemosyne

# GitHub credential encryption (Fernet key: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
TOKEN_ENCRYPTION_KEY=

# Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Frontend
PUBLIC_API_BASE_URL=http://localhost:8000
